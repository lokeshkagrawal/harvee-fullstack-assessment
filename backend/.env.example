# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=harvee_assessment
DB_USER=postgres
DB_PASSWORD=your_password_here

# Gemini AI API (Google AI Studio - https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here
